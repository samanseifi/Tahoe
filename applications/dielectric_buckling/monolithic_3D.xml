<?xml version="1.0" encoding="UTF-8"?>
<!--
  3D monolithic dielectric-elastomer buckling — direct 3D analog of
  tahoe-inputs/film/Buckling/straight_2.xml (the working 2D reference).

  Geometry: x in [-10,10], y in [-0.5,0.5], z in [0,1]
    40 x 2 x 2 hex8 elements (beam_3D.geom)

  Node-set numbering (matches generate_beam_3D.py):
    1  y = -0.5   ground electrode      (Psi = 0)
    2  x = +10    right clamp           (D_X = D_Y = D_Z = 0)
    3  y = +0.5   driven electrode      (Psi = V)
    4  x = -10    left clamp            (D_X = D_Y = D_Z = 0)
    5  z =  0     side roller           (D_Z = 0)
    6  z =  Lz    side roller           (D_Z = 0)

  Physics matches straight_2.xml exactly:
    - Constant voltage from t=0 (no ramp)
    - Nrig = 1e10 (nearly incompressible)
    - 4700 steps x dt=0.01, output every 10 steps
-->
<tahoe author="samansei" compute_IC="false"
    geometry_file="beam_3D.geom" output_format="ExodusII"
    title="3D Dielectric Elastomer Q1P0 Buckling" xmlns:x0="http://www.w3.org/2001/XMLSchema">
    <time num_steps="4700" output_inc="10" time_step="0.01">
        <schedule_function>
            <piecewise_linear>
                <OrderedPair x="0" y="1.0"/>
                <OrderedPair x="10000000" y="1.0"/>
            </piecewise_linear>
        </schedule_function>
    </time>
    <nodes>
        <field field_name="displacement" integrator="nonlinear_HHT">
            <dof_labels>
                <String value="D_X"/>
                <String value="D_Y"/>
                <String value="D_Z"/>
            </dof_labels>
            <!-- right clamp (x=+10): fix all DOF -->
            <kinematic_BC dof="1" node_ID="2" type="fixed"/>
            <kinematic_BC dof="2" node_ID="2" type="fixed"/>
            <kinematic_BC dof="3" node_ID="2" type="fixed"/>
            <!-- left clamp (x=-10): fix all DOF -->
            <kinematic_BC dof="1" node_ID="4" type="fixed"/>
            <kinematic_BC dof="2" node_ID="4" type="fixed"/>
            <kinematic_BC dof="3" node_ID="4" type="fixed"/>
            <!-- z=0 roller: fix D_Z -->
            <kinematic_BC dof="3" node_ID="5" type="fixed"/>
            <!-- z=Lz roller: fix D_Z -->
            <kinematic_BC dof="3" node_ID="6" type="fixed"/>
        </field>
        <field field_name="electric_scalar_potential" integrator="static">
            <dof_labels>
                <String value="Psi"/>
            </dof_labels>
            <!-- ground electrode (y=-0.5): Psi = 0 -->
            <kinematic_BC dof="1" node_ID="1" type="fixed"/>
            <!-- driven electrode (y=+0.5): Psi = 0.357 constant -->
            <kinematic_BC dof="1" node_ID="3" schedule="1" type="u" value="0.357"/>
        </field>
        <history_node_ID_list>
            <String value="3"/>
        </history_node_ID_list>
    </nodes>
    <element_list>
        <dielectric_elastomer_Q1P0
            electric_field_name="electric_scalar_potential"
            field_name="displacement" mass_type="lumped_mass">
            <hexahedron/>
            <solid_element_nodal_output displacements="1"
                electric_displacement="1" electric_scalar_potential="1" stress="1"/>
            <large_strain_element_block>
                <block_ID_list>
                    <String value="1"/>
                </block_ID_list>
                <large_strain_material_3D>
                    <Dielectric_Elastomer_Q1P0
                        Nrig="10000000000.0"
                        density="1.0" epsilon="1.0"
                        lambda="1000.0" mu="1.0"
                        Young_Modulus="2.997" Poisson="0.4995"/>
                </large_strain_material_3D>
            </large_strain_element_block>
        </dielectric_elastomer_Q1P0>
    </element_list>
    <nonlinear_solver abs_tolerance="1.0e-7"
        check_LHS_perturbation="1.0E-8" check_code="no_check"
        divergence_tolerance="1.0e+10" max_iterations="500" rel_tolerance="1.0e-9">
        <SPOOLES_matrix/>
    </nonlinear_solver>
</tahoe>
