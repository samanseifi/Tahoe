<?xml version="1.0"?>
<!--
  Dielectric-elastomer plate buckling — STAGGERED IMPLICIT.

  Same staggered Maxwell-stress coupling as staggered_explicit.xml, but the
  mechanical pass is integrated with an IMPLICIT scheme (nonlinear_HHT, Newton
  iteration with SPOOLES) instead of central-difference. Larger time steps,
  unconditional stability — at the cost of a matrix solve per Newton iteration
  per step.

  Pass 1 (implicit static):  diffusion / linear_dielectric_material  ->  Psi
  Pass 2 (implicit dynamic): updated_lagrangian_Q1P0 (nonlinear_HHT) ->  u

  We *cannot* use the monolithic 3D dielectric_elastomer / dielectric_elastomer_Q1P0
  elements as the "fully coupled" reference — both have bugs in this build:
    - dielectric_elastomer_Q1P0 (3D): tangent goes NaN on iteration 1, even on
      a single hex. The material's Young_Modulus / Poisson parameters are
      registered but never used; the 3D Q1P0 path appears unfinished and is
      not exercised by any benchmark in the tree.
    - dielectric_elastomer (3D, non-Q1P0): works on a single hex, but on a
      multi-element mesh both SPOOLES and MUMPS abort with heap corruption
      ("double free" / "malloc(): invalid size") when assembling the coupled
      4-DOF/node tangent. SimoQ1P0 with a separate diffusion field is the
      tested 3D path.

  So the explicit/implicit comparison is between the same staggered scheme
  with different mechanical time integrators — same Maxwell-stress coupling,
  same mesh, same BCs, same loading.
-->
<tahoe xmlns:x0="http://www.w3.org/2001/XMLSchema"
    geometry_file="plate.geom"
    output_format="ExodusII"
    title="Dielectric elastomer plate buckling — staggered implicit">

    <time num_steps="200" output_inc="5" time_step="0.01">
        <schedule_function>
            <piecewise_linear>
                <OrderedPair x="0.0" y="0.0"/>
                <OrderedPair x="2.0" y="1.0"/>
                <OrderedPair x="100.0" y="1.0"/>
            </piecewise_linear>
        </schedule_function>
    </time>

    <nodes>
        <field field_name="electric_scalar_potential" integrator="static" solution_group="1">
            <dof_labels>
                <String value="Psi"/>
            </dof_labels>
            <kinematic_BC dof="1" node_ID="5" type="fixed"/>
            <kinematic_BC dof="1" node_ID="6" schedule="1" type="u" value="1.5"/>
        </field>

        <field field_name="displacement" integrator="nonlinear_HHT" solution_group="2">
            <dof_labels>
                <String value="D_X"/>
                <String value="D_Y"/>
                <String value="D_Z"/>
            </dof_labels>
            <!-- clamped ends -->
            <kinematic_BC dof="1" node_ID="1" type="fixed"/>
            <kinematic_BC dof="2" node_ID="1" type="fixed"/>
            <kinematic_BC dof="3" node_ID="1" type="fixed"/>
            <kinematic_BC dof="1" node_ID="2" type="fixed"/>
            <kinematic_BC dof="2" node_ID="2" type="fixed"/>
            <kinematic_BC dof="3" node_ID="2" type="fixed"/>
            <!-- side rollers -->
            <kinematic_BC dof="2" node_ID="3" type="fixed"/>
            <kinematic_BC dof="2" node_ID="4" type="fixed"/>
        </field>
    </nodes>

    <element_list>
        <diffusion field_name="electric_scalar_potential">
            <hexahedron/>
            <diffusion_element_nodal_output displacement="1" coordinates="1"/>
            <diffusion_element_block>
                <block_ID_list>
                    <String value="1"/>
                </block_ID_list>
                <diffusion_material>
                    <linear_dielectric_material epsilon="1.0"/>
                </diffusion_material>
            </diffusion_element_block>
        </diffusion>

        <updated_lagrangian_Q1P0
            field_name="displacement"
            mass_type="lumped_mass"
            epsilon="1.0">
            <hexahedron/>
            <solid_element_nodal_output displacements="1" stress="1" material_output="1"/>
            <large_strain_element_block>
                <block_ID_list>
                    <String value="1"/>
                </block_ID_list>
                <large_strain_material_3D>
                    <RG_split_general density="1.0">
                        <rg_eq_potential>
                            <neo-hookean kappa="100.67" mu="1.0"/>
                        </rg_eq_potential>
                    </RG_split_general>
                </large_strain_material_3D>
            </large_strain_element_block>
        </updated_lagrangian_Q1P0>
    </element_list>

    <!-- Solver 1: implicit linear electrostatics -->
    <linear_solver>
        <SPOOLES_matrix/>
    </linear_solver>
    <!-- Solver 2: implicit dynamic mechanics (Newton-Raphson) -->
    <nonlinear_solver
        abs_tolerance="1.0e-7"
        rel_tolerance="1.0e-9"
        divergence_tolerance="1.0e+10"
        max_iterations="50">
        <SPOOLES_matrix/>
    </nonlinear_solver>

    <solver_phases max_loops="20">
        <solver_phase iterations="1" pass_iterations="0" solver="1"/>
        <solver_phase iterations="20" pass_iterations="0" solver="2"/>
    </solver_phases>
</tahoe>
