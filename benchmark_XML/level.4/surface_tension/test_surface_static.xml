<?xml version="1.0" encoding="UTF-8"?>
<tahoe author="samansei" compute_IC="false"
    geometry_file="../geometry/block/block.geom"
    output_format="ExodusII" title="Dielectric Elastomer Testing" xmlns:x0="http://www.w3.org/2001/XMLSchema">
    <time num_steps="1000" output_inc="10" time_step="1">
        <schedule_function>
            <piecewise_linear>
                <OrderedPair x="0" y="0"/>
                <OrderedPair x="10000" y="10000"/>
            </piecewise_linear>
        </schedule_function>
    </time>
    <nodes>
        <field field_name="displacement" integrator="static">
            <dof_labels>
                <String value="D_X"/>
                <String value="D_Y"/>
            </dof_labels>
            <kinematic_BC dof="1" node_ID="2" type="fixed"/>
            <kinematic_BC dof="2" node_ID="2" type="fixed"/>
        </field>
        <history_node_ID_list>
            <String value="3"/>
        </history_node_ID_list>
    </nodes>
    <element_list>
        <updated_lagrangian_Q1P0_surface field_name="displacement" mass_type="lumped_mass">
            <quadrilateral/>
            <solid_element_nodal_output coordinates="1"
                displacements="1" strain="1" stress="1"/>
            <large_strain_element_block>
                <block_ID_list>
                    <String value="1"/>
                </block_ID_list>
                <large_strain_material_2D>
                    <RG_split_general constraint_2D="plane_strain"  density="1">
                        <rg_eq_potential>
                            <neo-hookean kappa="100" mu="1.0"/>
                        </rg_eq_potential>
                    </RG_split_general>
                </large_strain_material_2D>
            </large_strain_element_block>
            <surface_tension side_set_ID="1" gamma="1" t_0="1.0"/>
            <surface_tension side_set_ID="3" gamma="1" t_0="1.0"/>
            <surface_tension side_set_ID="4" gamma="1" t_0="1.0"/>

        </updated_lagrangian_Q1P0_surface>
    </element_list>
    <nonlinear_solver abs_tolerance="1.0e-7" check_LHS_perturbation="1.0E-8" check_code="no_check" divergence_tolerance="1.0e+10" max_iterations="10" rel_tolerance="1.0e-9">
        <MUMPS_matrix/>
    </nonlinear_solver>
</tahoe>
