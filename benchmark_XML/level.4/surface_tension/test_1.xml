<?xml version="1.0" encoding="UTF-8"?>
<tahoe author="samansei" compute_IC="false"
    geometry_file="../geometry/block/block.geom"
    output_format="ExodusII" title="Dielectric Elastomer Testing" xmlns:x0="http://www.w3.org/2001/XMLSchema">
    <time num_steps="10000000" output_inc="1000" time_step="0.001">
        <schedule_function>
            <piecewise_linear>
                <OrderedPair x="0" y="0"/>
                <OrderedPair x="10000000" y="10000000"/>
            </piecewise_linear>
        </schedule_function>
    </time>
    <nodes>
        <field field_name="displacement" integrator="central_difference">
            <dof_labels>
                <String value="D_X"/>
                <String value="D_Y"/>
            </dof_labels>
            <kinematic_BC dof="1" node_ID="2" type="fixed"/>
            <kinematic_BC dof="2" node_ID="2" type="fixed"/>
        </field>
        <history_node_ID_list>
            <String value="3"/>
        </history_node_ID_list>
    </nodes>
    <element_list>
        <updated_lagrangian_Q1P0 field_name="displacement" mass_type="lumped_mass">
            <quadrilateral/>
            <solid_element_nodal_output coordinates="1"
                displacements="1" strain="1" stress="1"/>
            <large_strain_element_block>
                <block_ID_list>
                    <String value="1"/>
                </block_ID_list>
                <large_strain_material_2D>
                    <RG_split_general constraint_2D="plane_strain"  density="1">
                        <rg_eq_potential>
                            <neo-hookean kappa="1000" mu="2.0"/>
                        </rg_eq_potential>
                    </RG_split_general>
                </large_strain_material_2D>
            </large_strain_element_block>
        </updated_lagrangian_Q1P0>
    </element_list>
    <linear_solver>
        <SPOOLES_matrix/>
    </linear_solver>
</tahoe>
