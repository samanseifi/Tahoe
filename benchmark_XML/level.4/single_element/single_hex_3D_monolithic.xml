<?xml version="1.0" encoding="UTF-8"?>
<!-- Single hex 3D dielectric elastomer Q1P0 monolithic test.
     Uses nonlinear_HHT integrator (same as working 2D straight_2.xml).
     Node sets:
       1  z=0 face  -> ground electrode (Psi=0)
       2  z=1 face  -> driven electrode (Psi=V)
       3  node 1    -> fully clamped (D_X=D_Y=D_Z=0)
       4  nodes 2,6 -> fix D_Y, D_Z (remove 2 rotations)
       5  node 3    -> fix D_Z      (remove last rotation)
-->
<tahoe author="test" compute_IC="false"
    geometry_file="single_hex_3D.geom" output_format="ExodusII"
    title="3D Dielectric Elastomer Q1P0 single hex" xmlns:x0="http://www.w3.org/2001/XMLSchema">
    <time num_steps="10" output_inc="5" time_step="0.1">
        <schedule_function>
            <piecewise_linear>
                <OrderedPair x="0" y="0"/>
                <OrderedPair x="1.0" y="1.0"/>
            </piecewise_linear>
        </schedule_function>
    </time>
    <nodes>
        <field field_name="displacement" integrator="nonlinear_HHT">
            <dof_labels>
                <String value="D_X"/>
                <String value="D_Y"/>
                <String value="D_Z"/>
            </dof_labels>
            <kinematic_BC dof="1" node_ID="3" type="fixed"/>
            <kinematic_BC dof="2" node_ID="3" type="fixed"/>
            <kinematic_BC dof="3" node_ID="3" type="fixed"/>
            <kinematic_BC dof="2" node_ID="4" type="fixed"/>
            <kinematic_BC dof="3" node_ID="4" type="fixed"/>
            <kinematic_BC dof="3" node_ID="5" type="fixed"/>
        </field>
        <field field_name="electric_scalar_potential" integrator="static">
            <dof_labels>
                <String value="Psi"/>
            </dof_labels>
            <kinematic_BC dof="1" node_ID="1" type="fixed"/>
            <kinematic_BC dof="1" node_ID="2" schedule="1" type="u" value="0.1"/>
        </field>
    </nodes>
    <element_list>
        <dielectric_elastomer_Q1P0
            electric_field_name="electric_scalar_potential"
            field_name="displacement" mass_type="lumped_mass">
            <hexahedron/>
            <solid_element_nodal_output displacements="1"
                electric_displacement="1" electric_scalar_potential="1" stress="1"/>
            <large_strain_element_block>
                <block_ID_list>
                    <String value="1"/>
                </block_ID_list>
                <large_strain_material_3D>
                    <Dielectric_Elastomer_Q1P0
                        Nrig="5.0"
                        density="1.0" epsilon="1.0"
                        lambda="1000.0" mu="1.0"
                        Young_Modulus="2.997" Poisson="0.4995"/>
                </large_strain_material_3D>
            </large_strain_element_block>
        </dielectric_elastomer_Q1P0>
    </element_list>
    <nonlinear_solver abs_tolerance="1.0e-7"
        divergence_tolerance="1.0e+10" max_iterations="50" rel_tolerance="1.0e-9">
        <SPOOLES_matrix/>
    </nonlinear_solver>
</tahoe>
