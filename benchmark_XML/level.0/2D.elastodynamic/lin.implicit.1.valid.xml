<?xml version='1.0' encoding='US-ASCII' standalone='no' ?>

<tahoe
    geometry_format='automatic'
      geometry_file='../geometry/beam.0.geom'
      output_format='automatic'
 restart_output_inc='0'
         echo_input='false'
            logging='moderate'
         compute_IC='true'>
	<time
	       scaling='linear'
	     init_time='0.000000e+00'
	     num_steps='10'
	    output_inc='5'
	 max_step_cuts='0'
	     time_step='5.000000e-01'>
		<schedule_function>
			<piecewise_linear>
				<OrderedPair
				 x='0.000000e+00'
				 y='1.000000e+00'/>
			</piecewise_linear>
		</schedule_function>
	</time>
	<nodes>
		<field
		              field_name='displacement'
		          solution_group='1'
		              integrator='linear_HHT'
		 total_energy_output_inc='0'>
			<dof_labels>
				<String
				 value='D_X'/>
				<String
				 value='D_Y'/>
			</dof_labels>
			<kinematic_BC
			  node_ID='1'
			      dof='1'
			     type='fixed'
			 schedule='0'
			    value='0.000000e+00'/>
			<kinematic_BC
			  node_ID='1'
			      dof='2'
			     type='fixed'
			 schedule='0'
			    value='0.000000e+00'/>
			<force_BC
			  node_ID='2'
			      dof='1'
			 schedule='1'
			    value='-1.000000e-02'/>
		</field>
	</nodes>
	<element_list>
		<small_strain
		          field_name='displacement'
		           mass_type='automatic'
		      eigenvalue_inc='0'
		 strain_displacement='standard'>
			<quadrilateral
			 num_ip='4'/>
			<solid_element_nodal_output
			   displacements='1'
			          stress='1'
			 material_output='1'/>
			<solid_element_element_output
			 linear_momentum='1'/>
			<small_strain_element_block>
				<block_ID_list>
					<String
					 value='1'/>
				</block_ID_list>
				<small_strain_material_2D>
					<small_strain_StVenant_2D
					       density='1.000000e+00'
					 constraint_2D='plane_stress'
					           CTE='0.000000e+00'>
						<E_and_nu
						 Young_modulus='1.000000e+02'
						 Poisson_ratio='2.500000e-01'/>
					</small_strain_StVenant_2D>
				</small_strain_material_2D>
			</small_strain_element_block>
		</small_strain>
	</element_list>
	<linear_solver
	            print_eqnos='false'
	             check_code='no_check'
	 check_LHS_perturbation='1.000000e-08'>
		<profile_matrix/>
	</linear_solver>
</tahoe>
