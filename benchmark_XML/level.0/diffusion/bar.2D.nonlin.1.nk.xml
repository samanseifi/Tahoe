<?xml version="1.0"?>
<!-- bar.2D.nonlin.1.nk.xml
     Same as bar.2D.nonlin.1.xml (steady-state nonlinear diffusion on a 4x1 bar)
     but solved with the Newton-Krylov solver using GMRES(m) inner iterations
     instead of the direct SPOOLES factorization.

     Comparison benchmark:
       bar.2D.nonlin.1.xml   — Newton + SPOOLES direct solve
       bar.2D.nonlin.1.nk.xml — Newton-Krylov + GMRES(30) + Jacobi preconditioner
-->
<tahoe xmlns:x0="http://www.w3.org/2001/XMLSchema" geometry_file="../geometry/quad4.4x1.geom">
    <time num_steps="1" output_inc="1" time_step="1.0">
        <schedule_function>
            <piecewise_linear>
                <OrderedPair x="0.0" y="0.0"/>
                <OrderedPair x="1.0" y="1.0"/>
            </piecewise_linear>
        </schedule_function>
    </time>
    <nodes>
        <field field_name="temperature">
            <dof_labels>
                <String value="T"/>
            </dof_labels>
            <kinematic_BC dof="1" node_ID="3" schedule="1" type="u" value="-1.0"/>
            <kinematic_BC dof="1" node_ID="4" schedule="1" type="u" value="1.0"/>
        </field>
    </nodes>
    <element_list>
        <nonlinear_diffusion field_name="temperature">
            <quadrilateral/>
            <diffusion_element_nodal_output displacement="1" material_output="1"/>
            <diffusion_element_block>
                <block_ID_list>
                    <String value="1"/>
                </block_ID_list>
                <diffusion_material>
                    <nonlinear_diffusion_material conductivity="1.0" density="1.0" specific_heat="1.0">
                        <conductivity_function>
                            <linear_function a="-1.0" b="1.0"/>
                        </conductivity_function>
                        <specificheat_function>
                            <linear_function a="0.0" b="1.0"/>
                        </specificheat_function>
                    </nonlinear_diffusion_material>
                </diffusion_material>
            </diffusion_element_block>
        </nonlinear_diffusion>
    </element_list>
    <!--
      Newton-Krylov solver:
        abs_tolerance / rel_tolerance / max_iterations control the outer Newton loop
        (same as for nonlinear_solver).
        gmres_restart:    Krylov subspace dimension before restart (m).
        linear_tolerance: RELATIVE residual tolerance for the inner GMRES solve.
                          GMRES stops when ||r_j|| / ||r_0|| < linear_tolerance.
                          1.0e-8 is tight enough to match the Newton direct solver's
                          machine-precision convergence (relative error ~10^-16).
                          For production runs a looser value (1.0e-3 to 1.0e-6) can
                          reduce the total number of matrix-vector products, at the
                          cost of slightly more outer Newton iterations.
        max_linear_iter:  maximum total GMRES matrix-vector products per Newton step
                          (0 = 3*n automatic limit).
      The profile_matrix stores the tangent stiffness; Multx() is used for
      matrix-vector products instead of a direct factorization.
    -->
    <newton_krylov_solver abs_tolerance="1.0e-10" divergence_tolerance="10.0"
                          max_iterations="5" rel_tolerance="1.0e-12"
                          gmres_restart="30" linear_tolerance="1.0e-8"
                          max_linear_iter="0">
        <profile_matrix/>
    </newton_krylov_solver>
</tahoe>
