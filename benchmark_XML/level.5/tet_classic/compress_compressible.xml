<?xml version="1.0"?>
<!-- Plain Tet4 quasistatic uniaxial-STRESS compression (lateral free).
     Near-incompressible Neo-Hookean (kappa=1000, mu=1 -> nu ~ 0.498).
     Plain Tet4 will lock badly under this loading; the same problem with
     BonetTet (compress_bonet_tet.xml) and Q1P0 hex (compress_hex_q1p0.xml)
     give the comparison set. -->
<tahoe geometry_file="../explicit_benchmark/geometry/tet_small.geom"
       output_format="ExodusII"
       title="BonetTet ANP near-incompressible uniaxial stress (no locking)">
    <time num_steps="5" output_inc="1" time_step="0.2">
        <schedule_function>
            <piecewise_linear>
                <OrderedPair x="0.0" y="0.0"/>
                <OrderedPair x="1.0" y="1.0"/>
            </piecewise_linear>
        </schedule_function>
    </time>
    <nodes>
        <field field_name="displacement">
            <dof_labels>
                <String value="D_X"/>
                <String value="D_Y"/>
                <String value="D_Z"/>
            </dof_labels>
            <!-- z=0 face fixed in z (rigid wall surrogate) -->
            <kinematic_BC dof="3" node_ID="5"/>
            <!-- pin x=0 face dof_x and y=0 face dof_y for symmetry / no rigid drift -->
            <kinematic_BC dof="1" node_ID="1"/>
            <kinematic_BC dof="2" node_ID="2"/>
            <!-- z=L_z face: compress by 5% (uniaxial-stress: lateral faces free) -->
            <kinematic_BC dof="3" node_ID="4" schedule="1" type="u" value="-0.05"/>
        </field>
    </nodes>
    <element_list>
        <bonet_tet field_name="displacement">
            <tetrahedron/>
            <solid_element_nodal_output displacements="1" stress="1"/>
            <large_strain_element_block>
                <block_ID_list>
                    <String value="1"/>
                </block_ID_list>
                <large_strain_material_3D>
                    <RG_split_general density="1.0">
                        <rg_eq_potential>
                            <neo-hookean kappa="10.0" mu="1.0"/>
                        </rg_eq_potential>
                    </RG_split_general>
                </large_strain_material_3D>
            </large_strain_element_block>
        </bonet_tet>
    </element_list>
    <!-- BonetTet residual uses F_bar but inherited UL analytical tangent
         is from F.  Newton stalls under near-incompressibility (kappa>>mu)
         because of this inconsistency.  Need numerical or analytical
         Bonet-Burton tangent for tight tolerances. -->
    <nonlinear_solver abs_tolerance="1.0e-6" divergence_tolerance="1.0e+04"
                      max_iterations="200" rel_tolerance="1.0e-3">
        <profile_matrix/>
    </nonlinear_solver>
</tahoe>
