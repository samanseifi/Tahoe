<?xml version="1.0"?>
<!-- Classic Tahoe Tet4 quasistatic implicit benchmark.

     A unit cube tet-meshed with 182 Tet4 elements (toolbox/.../tet4.geom)
     under uniform stretch of node set 1 (one face) by 10% in 5 increments.
     Solver: Newton iteration on profile matrix.  Material: Neo-Hookean
     wrapped in RG_split_general (the same hyperelastic potential used by
     the explicit benchmarks).

     Demonstrates that classic Tahoe's Tet4 path (UpdatedLagrangianT
     + TetrahedronT geometry from toolbox) handles quasistatic hyperelasticity
     out of the box — the new Tet4KernelT (#27) is the explicit-dynamics
     fast path, but does not preclude the classic implicit path.

     Caveat: plain Tet4 locks under near-incompressibility (kappa >> mu,
     or large plastic flow).  The ANP fix (#28) addresses that — the helper
     will be reusable here once added.
-->
<tahoe geometry_file="../../level.0/geometry/tet4.geom"
       output_format="ExodusII"
       title="Classic Tahoe BonetTet (ANP-Tet4) quasistatic Neo-Hookean">
    <time num_steps="5" output_inc="1" time_step="0.2">
        <schedule_function>
            <piecewise_linear>
                <OrderedPair x="0.0" y="0.0"/>
                <OrderedPair x="1.0" y="1.0"/>
            </piecewise_linear>
        </schedule_function>
    </time>
    <nodes>
        <field field_name="displacement">
            <dof_labels>
                <String value="D_X"/>
                <String value="D_Y"/>
                <String value="D_Z"/>
            </dof_labels>
            <!-- node set 1 = all surface nodes (56 of 67).  Apply a uniform
                 10% stretch in X via mapped_nodes (each surface node moves
                 by 0.1 * x_initial).  Interior nodes (11) are free, so the
                 Newton solver finds the equilibrium hyperelastic response. -->
            <mapped_nodes schedule="1">
                <Matrix_3x3 A_1_1="0.10"/>
                <mapped_node_ID_list>
                    <String value="1"/>
                </mapped_node_ID_list>
            </mapped_nodes>
        </field>
    </nodes>
    <element_list>
        <bonet_tet field_name="displacement">
            <tetrahedron/>
            <solid_element_nodal_output displacements="1" stress="1"/>
            <large_strain_element_block>
                <block_ID_list>
                    <String value="1"/>
                </block_ID_list>
                <large_strain_material_3D>
                    <RG_split_general density="1.0">
                        <rg_eq_potential>
                            <neo-hookean kappa="100.0" mu="40.0"/>
                        </rg_eq_potential>
                    </RG_split_general>
                </large_strain_material_3D>
            </large_strain_element_block>
        </bonet_tet>
    </element_list>
    <!-- Note: BonetTet residual uses F_bar but the analytical tangent
         (inherited from UpdatedLagrangianT) is computed from F.  Newton
         stalls near ~1e-7 relative error because of this inconsistency.
         Setting rel_tol to 1e-5 passes; a future enhancement is a
         numerical (forward-difference) tangent or an analytical
         Bonet-Burton tangent. -->
    <nonlinear_solver abs_tolerance="1.0e-8" divergence_tolerance="1.0e+04"
                      max_iterations="50" rel_tolerance="1.0e-5">
        <profile_matrix/>
    </nonlinear_solver>
</tahoe>
