<?xml version="1.0"?>
<!-- Dynamic impact test for #19: upper cube has initial velocity, hits
     lower cube via penalty contact. Verifies explicit + contact dynamics,
     momentum/energy transfer across contact interface. -->
<tahoe geometry_file="../../level.2/geometry/two_cubes.1.geom"
       output_format="ExodusII"
       title="Explicit dynamic impact: cube-on-cube through penalty contact">
    <time num_steps="5000" output_inc="50" time_step="1.0e-04">
        <schedule_function>
            <piecewise_linear>
                <OrderedPair x="0.0" y="0.0"/>
                <OrderedPair x="1.0" y="1.0"/>
            </piecewise_linear>
        </schedule_function>
    </time>
    <nodes>
        <field field_name="displacement" integrator="central_difference">
            <dof_labels>
                <String value="D_X"/>
                <String value="D_Y"/>
                <String value="D_Z"/>
            </dof_labels>
            <!-- initial downward velocity on upper cube (nodes 9-16 = sets 3+4) -->
            <initial_condition dof="3" node_ID="3" type="D_u" value="-5.0"/>
            <initial_condition dof="3" node_ID="4" type="D_u" value="-5.0"/>
            <!-- lower cube bottom face fully fixed -->
            <kinematic_BC dof="1" node_ID="1"/>
            <kinematic_BC dof="2" node_ID="1"/>
            <kinematic_BC dof="3" node_ID="1"/>
        </field>
    </nodes>
    <element_list>
        <explicit_solid field_name="displacement" mass_type="lumped_mass">
            <hexahedron/>
            <solid_element_nodal_output displacements="1" velocities="1" stress="1"/>
            <large_strain_element_block>
                <block_ID_list>
                    <String value="1"/>
                </block_ID_list>
                <large_strain_material_3D>
                    <RG_split_general density="1.0">
                        <rg_eq_potential>
                            <neo-hookean kappa="100.0" mu="40.0"/>
                        </rg_eq_potential>
                    </RG_split_general>
                </large_strain_material_3D>
            </large_strain_element_block>
        </explicit_solid>

        <contact_3D_penalty field_name="displacement" penalty_stiffness="500.0">
            <contact_surface>
                <surface_side_set side_set_ID="1"/>
            </contact_surface>
            <contact_surface>
                <surface_side_set side_set_ID="2"/>
            </contact_surface>
            <!-- symmetric contact: both interface node sets are strikers.
                 ns2 = top of cube 1 (Z=1), ns3 = bottom of cube 2 (Z=1). -->
            <contact_nodes>
                <node_ID_list>
                    <String value="2"/>
                    <String value="3"/>
                </node_ID_list>
            </contact_nodes>
        </contact_3D_penalty>
    </element_list>
    <linear_solver>
        <diagonal_matrix/>
    </linear_solver>
</tahoe>
