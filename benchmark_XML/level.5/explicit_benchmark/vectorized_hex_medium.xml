<?xml version="1.0"?>
<!-- Legacy explicit 3D benchmark: 2000 Hex8 elements, explicit_solid -->
<tahoe geometry_file="geometry/hex_medium.geom" output_format="ExodusII"
    title="Legacy explicit 3D benchmark (medium)">
    <time num_steps="10000" output_inc="10000" time_step="1.0e-05">
        <schedule_function>
            <piecewise_linear>
                <OrderedPair x="0.0" y="0.0"/>
                <OrderedPair x="1.0" y="1.0"/>
            </piecewise_linear>
        </schedule_function>
    </time>
    <nodes>
        <field field_name="displacement" integrator="central_difference">
            <dof_labels>
                <String value="D_X"/>
                <String value="D_Y"/>
                <String value="D_Z"/>
            </dof_labels>
            <!-- fix x=0 face -->
            <kinematic_BC dof="1" node_ID="1"/>
            <kinematic_BC dof="2" node_ID="1"/>
            <kinematic_BC dof="3" node_ID="1"/>
            <!-- pull x=Lx face -->
            <kinematic_BC dof="1" node_ID="2" schedule="1" type="u" value="0.01"/>
        </field>
    </nodes>
    <element_list>
        <explicit_solid field_name="displacement" mass_type="lumped_mass">
            <hexahedron/>
            <large_strain_element_block>
                <block_ID_list>
                    <String value="1"/>
                </block_ID_list>
                <large_strain_material_3D>
                    <RG_split_general density="1.0">
                        <rg_eq_potential>
                            <neo-hookean kappa="1000.0" mu="5.0"/>
                        </rg_eq_potential>
                    </RG_split_general>
                </large_strain_material_3D>
            </large_strain_element_block>
        </explicit_solid>
    </element_list>
    <linear_solver>
        <SPOOLES_matrix/>
    </linear_solver>
</tahoe>
