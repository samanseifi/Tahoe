<?xml version="1.0"?>
<!-- Minimal Tet4 test: free body with initial velocity, no wall, no plasticity.
     Should translate as a rigid body at constant velocity. -->
<tahoe geometry_file="geometry/tet_small.geom"
       output_format="ExodusII"
       compute_IC="false"
       title="Tet4 minimal: free-body translation">
    <time num_steps="100" output_inc="20" time_step="1.0e-06">
        <schedule_function>
            <piecewise_linear>
                <OrderedPair x="0.0" y="0.0"/>
                <OrderedPair x="1.0e+06" y="1.0e+06"/>
            </piecewise_linear>
        </schedule_function>
    </time>
    <nodes>
        <field field_name="displacement" integrator="central_difference">
            <dof_labels>
                <String value="D_X"/>
                <String value="D_Y"/>
                <String value="D_Z"/>
            </dof_labels>
            <initial_condition dof="3" all_nodes="true" type="D_u" value="-0.190"/>
            <!-- minimal BC to prevent rigid-body drift in x/y: pin one node -->
            <kinematic_BC dof="1" node_ID="1"/>
            <kinematic_BC dof="2" node_ID="3"/>
        </field>
    </nodes>
    <element_list>
        <explicit_solid field_name="displacement" mass_type="lumped_mass">
            <tetrahedron/>
            <solid_element_nodal_output displacements="1"/>
            <large_strain_element_block>
                <block_ID_list>
                    <String value="1"/>
                </block_ID_list>
                <large_strain_material_3D>
                    <RG_split_general density="8.96e-3">
                        <rg_eq_potential>
                            <neo-hookean kappa="130000.0" mu="43333.0"/>
                        </rg_eq_potential>
                    </RG_split_general>
                </large_strain_material_3D>
            </large_strain_element_block>
        </explicit_solid>
    </element_list>
    <linear_solver>
        <diagonal_matrix/>
    </linear_solver>
</tahoe>
