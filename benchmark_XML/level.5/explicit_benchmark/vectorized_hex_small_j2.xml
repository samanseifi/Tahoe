<?xml version="1.0"?>
<!-- Smoke test: ExplicitElementT with J2 plasticity on a small 3D Hex8 block.
     The stretching is large enough to take the material past yield. -->
<tahoe geometry_file="geometry/hex_small.geom" output_format="ExodusII"
    title="Explicit J2 plasticity smoke test (small 3D)">
    <time num_steps="10000" output_inc="500" time_step="1.0e-05">
        <schedule_function>
            <piecewise_linear>
                <OrderedPair x="0.0" y="0.0"/>
                <OrderedPair x="1.0" y="1.0"/>
            </piecewise_linear>
        </schedule_function>
    </time>
    <nodes>
        <field field_name="displacement" integrator="central_difference">
            <dof_labels>
                <String value="D_X"/>
                <String value="D_Y"/>
                <String value="D_Z"/>
            </dof_labels>
            <kinematic_BC dof="1" node_ID="1"/>
            <kinematic_BC dof="2" node_ID="1"/>
            <kinematic_BC dof="3" node_ID="1"/>
            <kinematic_BC dof="1" node_ID="2" schedule="1" type="u" value="0.05"/>
        </field>
    </nodes>
    <element_list>
        <explicit_solid field_name="displacement" mass_type="lumped_mass">
            <hexahedron/>
            <solid_element_nodal_output displacements="1" stress="1"/>
            <large_strain_element_block>
                <block_ID_list>
                    <String value="1"/>
                </block_ID_list>
                <large_strain_material_3D>
                    <RG_split_general density="1.0">
                        <rg_eq_potential>
                            <neo-hookean kappa="1000.0" mu="50.0"/>
                        </rg_eq_potential>
                    </RG_split_general>
                </large_strain_material_3D>
            </large_strain_element_block>
            <!-- J2 plasticity parameters (mu/kappa come from the material
                 sub-tree above; J2 adds the plastic parameters here) -->
            <j2_plasticity sigma_Y="25.0" hardening="100.0"/>
        </explicit_solid>
    </element_list>
    <linear_solver>
        <diagonal_matrix/>
    </linear_solver>
</tahoe>
