<?xml version="1.0"?>
<!-- Friction sliding test (#26): two stacked cubes with prescribed
     compression on the top face (sustained normal contact), upper cube
     given initial X velocity.  Coulomb friction decelerates the X motion.

     Setup: bottom face fixed, top face pressed down 5% (steady compression).
     Upper cube nodes start with V_X = 2.0 mm/us.  Friction force opposes
     this motion; X displacement at t_final is reduced from the no-friction
     baseline.  -->
<tahoe geometry_file="../../level.2/geometry/two_cubes.1.geom"
       output_format="ExodusII"
       title="Sliding cube on cube with Coulomb friction (mu=0.3)">
    <time num_steps="5000" output_inc="100" time_step="1.0e-04">
        <schedule_function>
            <piecewise_linear>
                <OrderedPair x="0.0" y="0.0"/>
                <OrderedPair x="1.0" y="1.0"/>
            </piecewise_linear>
        </schedule_function>
    </time>
    <nodes>
        <field field_name="displacement" integrator="central_difference">
            <dof_labels>
                <String value="D_X"/>
                <String value="D_Y"/>
                <String value="D_Z"/>
            </dof_labels>
            <!-- give top cube nodes (9..16) initial X velocity -->
            <initial_condition dof="1" node_ID="3" type="D_u" value="2.0"/>
            <initial_condition dof="1" node_ID="4" type="D_u" value="2.0"/>
            <!-- bottom cube fully fixed -->
            <kinematic_BC dof="1" node_ID="1"/>
            <kinematic_BC dof="2" node_ID="1"/>
            <kinematic_BC dof="3" node_ID="1"/>
            <!-- top cube top face: hold Z = -0.05 (sustained 5% compression)
                 leave X and Y free so it can slide -->
            <kinematic_BC dof="3" node_ID="4" schedule="1" type="u" value="-0.05"/>
        </field>
    </nodes>
    <element_list>
        <explicit_solid field_name="displacement" mass_type="lumped_mass">
            <hexahedron/>
            <solid_element_nodal_output displacements="1" velocities="1" stress="1"/>
            <large_strain_element_block>
                <block_ID_list><String value="1"/></block_ID_list>
                <large_strain_material_3D>
                    <RG_split_general density="1.0">
                        <rg_eq_potential>
                            <neo-hookean kappa="1000.0" mu="400.0"/>
                        </rg_eq_potential>
                    </RG_split_general>
                </large_strain_material_3D>
            </large_strain_element_block>
        </explicit_solid>

        <contact_3D_penalty field_name="displacement"
                            penalty_stiffness="2000.0"
                            friction_coefficient="0.3"
                            friction_epsilon_velocity="0.001">
            <contact_surface>
                <surface_side_set side_set_ID="1"/>
            </contact_surface>
            <contact_surface>
                <surface_side_set side_set_ID="2"/>
            </contact_surface>
            <contact_nodes>
                <node_ID_list>
                    <String value="2"/>
                    <String value="3"/>
                </node_ID_list>
            </contact_nodes>
        </contact_3D_penalty>
    </element_list>
    <linear_solver>
        <diagonal_matrix/>
    </linear_solver>
</tahoe>
