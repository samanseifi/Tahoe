<?xml version="1.0"?>
<tahoe geometry_file="block_large.geom" output_format="ExodusII"
    title="Vectorized explicit benchmark with mass scaling (large)">
    <time num_steps="10000" output_inc="10000" time_step="1.0e-04">
        <schedule_function>
            <piecewise_linear>
                <OrderedPair x="0.0" y="0.0"/>
                <OrderedPair x="1.0" y="1.0"/>
            </piecewise_linear>
        </schedule_function>
    </time>
    <nodes>
        <field field_name="displacement" integrator="central_difference">
            <dof_labels>
                <String value="D_X"/>
                <String value="D_Y"/>
            </dof_labels>
            <kinematic_BC dof="1" node_ID="4"/>
            <kinematic_BC dof="2" node_ID="4"/>
            <kinematic_BC dof="1" node_ID="2" schedule="1" type="u" value="0.1"/>
        </field>
    </nodes>
    <element_list>
        <explicit_solid field_name="displacement" mass_type="lumped_mass">
            <quadrilateral num_ip="1"/>
            <large_strain_element_block>
                <block_ID_list><String value="1"/></block_ID_list>
                <large_strain_material_2D>
                    <RG_split_general constraint_2D="plane_strain" density="1.0">
                        <rg_eq_potential>
                            <neo-hookean kappa="1000.0" mu="5.0"/>
                        </rg_eq_potential>
                    </RG_split_general>
                </large_strain_material_2D>
            </large_strain_element_block>
            <hourglass_control type="viscous" coefficient="0.1"/>
            <mass_scaling type="fixed" target_dt="5.0e-04" scale_factor="0.9"/>
        </explicit_solid>
    </element_list>
    <linear_solver>
        <SPOOLES_matrix/>
    </linear_solver>
</tahoe>
