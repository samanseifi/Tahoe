<?xml version="1.0"?>
<!-- Verify ExplicitElementT + PenaltyContact3DT coexist (#19).
     Two cubes, upper pressed onto lower via prescribed displacement, explicit
     central-difference integration, batched MVSIZ path on both bodies. -->
<tahoe geometry_file="../../level.2/geometry/two_cubes.1.geom"
       output_format="ExodusII"
       title="Explicit + penalty contact verification (two cubes)">
    <time num_steps="2000" output_inc="100" time_step="5.0e-04">
        <schedule_function>
            <piecewise_linear>
                <OrderedPair x="0.0" y="0.0"/>
                <OrderedPair x="1.0" y="1.0"/>
            </piecewise_linear>
        </schedule_function>
    </time>
    <nodes>
        <field field_name="displacement" integrator="central_difference">
            <dof_labels>
                <String value="D_X"/>
                <String value="D_Y"/>
                <String value="D_Z"/>
            </dof_labels>
            <!-- fix bottom cube lower face (node set 1) in all DOF -->
            <kinematic_BC dof="1" node_ID="1"/>
            <kinematic_BC dof="2" node_ID="1"/>
            <kinematic_BC dof="3" node_ID="1"/>
            <!-- press upper cube top face (node set 4) down in Z -->
            <kinematic_BC dof="1" node_ID="4"/>
            <kinematic_BC dof="2" node_ID="4"/>
            <kinematic_BC dof="3" node_ID="4" schedule="1" type="u" value="-0.2"/>
        </field>
    </nodes>
    <element_list>
        <explicit_solid field_name="displacement" mass_type="lumped_mass">
            <hexahedron/>
            <solid_element_nodal_output displacements="1" stress="1"/>
            <large_strain_element_block>
                <block_ID_list>
                    <String value="1"/>
                </block_ID_list>
                <large_strain_material_3D>
                    <RG_split_general density="1.0">
                        <rg_eq_potential>
                            <neo-hookean kappa="100.0" mu="40.0"/>
                        </rg_eq_potential>
                    </RG_split_general>
                </large_strain_material_3D>
            </large_strain_element_block>
        </explicit_solid>

        <!-- Penalty contact: cube1 bottom face (ss1) vs cube2 top face (ss2) -->
        <contact_3D_penalty field_name="displacement" penalty_stiffness="200.0">
            <contact_surface>
                <surface_side_set side_set_ID="1"/>
            </contact_surface>
            <contact_surface>
                <surface_side_set side_set_ID="2"/>
            </contact_surface>
            <contact_nodes>
                <node_ID_list>
                    <String value="3"/>
                </node_ID_list>
            </contact_nodes>
        </contact_3D_penalty>
    </element_list>
    <linear_solver>
        <diagonal_matrix/>
    </linear_solver>
</tahoe>
