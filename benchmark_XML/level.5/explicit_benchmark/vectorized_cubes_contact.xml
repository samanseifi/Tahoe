<?xml version="1.0"?>
<!-- Verify ExplicitElementT + PenaltyContact3DT coexist (#19).
     Refined mesh: 5x5x5 hex per cube (250 hex total, 432 nodes) so the
     deformation field is visible in ParaView, not just 8 corner nodes.

     Geometry (generate_two_cubes_mesh.py):
       cube 1: [-0.5, 0.5]^2 x [0, 1]   block_ID 1, 125 elem
       cube 2: same in xy, z in [1, 2]  block_ID 2, 125 elem

     Node sets (NS):
       1 — bottom of cube 1 (z=0)        clamped
       2 — top of cube 2   (z=2)         driven
       3 — cube 1 interface (z=1)        contact strikers (cube-1 side)
       4 — cube 2 interface (z=1)        contact strikers (cube-2 side)

     Side sets (SS):
       1 — cube 1 top face   (master surface for cube-2 strikers)
       2 — cube 2 bottom face (master surface for cube-1 strikers)
-->
<tahoe geometry_file="geometry/two_cubes_refined.geom"
       output_format="ExodusII"
       title="Explicit + penalty contact (refined 5x5x5 per cube)">
    <time num_steps="2000" output_inc="100" time_step="5.0e-04">
        <schedule_function>
            <piecewise_linear>
                <OrderedPair x="0.0" y="0.0"/>
                <OrderedPair x="1.0" y="1.0"/>
            </piecewise_linear>
        </schedule_function>
    </time>
    <nodes>
        <field field_name="displacement" integrator="central_difference">
            <dof_labels>
                <String value="D_X"/>
                <String value="D_Y"/>
                <String value="D_Z"/>
            </dof_labels>
            <!-- bottom face (NS1) clamped -->
            <kinematic_BC dof="1" node_ID="1"/>
            <kinematic_BC dof="2" node_ID="1"/>
            <kinematic_BC dof="3" node_ID="1"/>
            <!-- top face (NS2) driven 0.2 down in z -->
            <kinematic_BC dof="1" node_ID="2"/>
            <kinematic_BC dof="2" node_ID="2"/>
            <kinematic_BC dof="3" node_ID="2" schedule="1" type="u" value="-0.2"/>
        </field>
    </nodes>
    <element_list>
        <explicit_solid field_name="displacement" mass_type="lumped_mass">
            <hexahedron/>
            <solid_element_nodal_output displacements="1" stress="1"/>
            <large_strain_element_block>
                <block_ID_list>
                    <String value="1"/>
                    <String value="2"/>
                </block_ID_list>
                <large_strain_material_3D>
                    <RG_split_general density="1.0">
                        <rg_eq_potential>
                            <neo-hookean kappa="100.0" mu="40.0"/>
                        </rg_eq_potential>
                    </RG_split_general>
                </large_strain_material_3D>
            </large_strain_element_block>
        </explicit_solid>

        <contact_3D_penalty field_name="displacement" penalty_stiffness="200.0">
            <contact_surface>
                <surface_side_set side_set_ID="1"/>
            </contact_surface>
            <contact_surface>
                <surface_side_set side_set_ID="2"/>
            </contact_surface>
            <contact_nodes>
                <node_ID_list>
                    <String value="3"/>
                    <String value="4"/>
                </node_ID_list>
            </contact_nodes>
        </contact_3D_penalty>
    </element_list>
    <linear_solver>
        <diagonal_matrix/>
    </linear_solver>
</tahoe>
