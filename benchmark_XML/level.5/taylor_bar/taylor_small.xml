<?xml version="1.0"?>
<!-- Taylor bar impact — small mesh for fast smoke/CI test.

     Problem:  Cu cylinder (square-section quarter-symmetry approximation),
               32.4 x 5.67 x 5.67 mm, initial velocity 0.190 mm/us (190 m/s)
               impacting rigid frictionless wall at z=0.
     Classic Wilkins-Guinan 1973 reference:  final length ~ 21.5 mm (33.6%
     axial compression), mushroom diameter ~ 2.1x initial (equivalent).

     Units: mm, us (microseconds), g, MPa (self-consistent)
       density rho = 8.96e-3 g/mm^3 (OFHC Cu)
       wave speed c ~ 4577 mm/us
       dt_cfl ~ 2.4e-4 us for this mesh
-->
<tahoe geometry_file="geometry/taylor_small.geom"
       output_format="ExodusII"
       title="Taylor bar impact (small, Cu) — quarter symmetry">
    <!-- dt = 1.0e-4 us, 40% of CFL.  60 us simulation = 600k steps.
         Output every 10k steps = 60 frames. -->
    <time num_steps="600000" output_inc="10000" time_step="1.0e-04">
        <schedule_function>
            <piecewise_linear>
                <OrderedPair x="0.0" y="0.0"/>
                <OrderedPair x="1.0e+06" y="1.0e+06"/>
            </piecewise_linear>
        </schedule_function>
    </time>
    <nodes>
        <field field_name="displacement" integrator="central_difference">
            <dof_labels>
                <String value="D_X"/>
                <String value="D_Y"/>
                <String value="D_Z"/>
            </dof_labels>
            <!-- initial velocity: -0.190 mm/us on the body (ns5 excludes wall) -->
            <initial_condition dof="3" node_ID="5" type="D_u" value="-0.190"/>
            <!-- symmetry BC x=0 plane -->
            <kinematic_BC dof="1" node_ID="1"/>
            <!-- symmetry BC y=0 plane -->
            <kinematic_BC dof="2" node_ID="2"/>
            <!-- rigid frictionless wall at z=0 -->
            <kinematic_BC dof="3" node_ID="3"/>
        </field>
    </nodes>
    <element_list>
        <explicit_solid field_name="displacement" mass_type="lumped_mass">
            <hexahedron/>
            <solid_element_nodal_output displacements="1" velocities="1" stress="1"/>
            <large_strain_element_block>
                <block_ID_list>
                    <String value="1"/>
                </block_ID_list>
                <large_strain_material_3D>
                    <RG_split_general density="8.96e-3">
                        <rg_eq_potential>
                            <!-- Cu: E=117e3 MPa, nu=0.35 -> mu=43333, kappa=130000 MPa -->
                            <neo-hookean kappa="130000.0" mu="43333.0"/>
                        </rg_eq_potential>
                    </RG_split_general>
                </large_strain_material_3D>
            </large_strain_element_block>
            <!-- Soft-metal demo parameters (sigma_Y << wave stress = rho*c*v
                 ~ 7.8 MPa), so plasticity engages on the flat impact face.
                 Real Cu Taylor bar plasticity at 190 m/s comes from a
                 cylindrical impact-face concentration not present in this
                 simplified prismatic mesh. -->
            <j2_plasticity sigma_Y="1.0" hardening="50.0"/>
        </explicit_solid>
    </element_list>
    <linear_solver>
        <diagonal_matrix/>
    </linear_solver>
</tahoe>
