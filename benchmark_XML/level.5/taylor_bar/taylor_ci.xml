<?xml version="1.0"?>
<!-- Taylor bar short CI smoke test — 1 us simulation, ~10 s runtime.

     Not a validation run (1 us is only ~5% of the first wave transit),
     but confirms the J2 plasticity + explicit stack runs end-to-end on a
     dynamic-impact problem without NaN/crash. Full validation uses
     taylor_small.xml (60 us, ~9 min). -->
<tahoe geometry_file="geometry/taylor_small.geom"
       output_format="ExodusII"
       compute_IC="false"
       title="Taylor bar CI smoke test (1 us)">
    <time num_steps="10000" output_inc="2000" time_step="1.0e-04">
        <schedule_function>
            <piecewise_linear>
                <OrderedPair x="0.0" y="0.0"/>
                <OrderedPair x="1.0e+06" y="1.0e+06"/>
            </piecewise_linear>
        </schedule_function>
    </time>
    <nodes>
        <field field_name="displacement" integrator="central_difference">
            <dof_labels>
                <String value="D_X"/>
                <String value="D_Y"/>
                <String value="D_Z"/>
            </dof_labels>
            <initial_condition dof="3" all_nodes="true" type="D_u" value="-0.190"/>
            <kinematic_BC dof="1" node_ID="1"/>
            <kinematic_BC dof="2" node_ID="2"/>
            <kinematic_BC dof="3" node_ID="3"/>
        </field>
    </nodes>
    <element_list>
        <explicit_solid field_name="displacement" mass_type="lumped_mass">
            <hexahedron/>
            <solid_element_nodal_output displacements="1" velocities="1" stress="1"/>
            <large_strain_element_block>
                <block_ID_list>
                    <String value="1"/>
                </block_ID_list>
                <large_strain_material_3D>
                    <RG_split_general density="8.96e-3">
                        <rg_eq_potential>
                            <neo-hookean kappa="130000.0" mu="43333.0"/>
                        </rg_eq_potential>
                    </RG_split_general>
                </large_strain_material_3D>
            </large_strain_element_block>
            <!-- Soft-metal demo parameters: yield well below the wave-stress
                 (sigma_wave ~ rho*c*v ~ 7.8 MPa), so plasticity engages
                 during impact even on a flat-faced prismatic geometry.
                 Real Cu (sigma_Y~90 MPa) requires cylindrical impact
                 concentration not present in this simplified mesh. -->
            <j2_plasticity sigma_Y="1.0" hardening="50.0"/>
        </explicit_solid>
    </element_list>
    <linear_solver>
        <diagonal_matrix/>
    </linear_solver>
</tahoe>
