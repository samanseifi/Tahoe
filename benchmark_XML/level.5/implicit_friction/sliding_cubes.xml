<?xml version="1.0"?>
<!-- Implicit Coulomb friction smoke test (#40) — WORK IN PROGRESS.

     Same two-cube geometry as the explicit friction benchmark (#26).
     Top face is pressed into the bottom cube by prescribed u_z = -0.005,
     then dragged tangentially in +x by prescribed u_x ramped 0 → 0.01 mm
     over 100 quasi-static load steps.  Newton-Raphson with the lagged
     slip-history Coulomb branch in PenaltyContact3DT.

     EXPECTED BEHAVIOUR TODAY: this XML *diverges* under the residual-only
     implicit-friction implementation that landed in PR #41.  The friction
     residual is correct, but PenaltyContact3DT::LHSDriver does not yet
     include the friction tangent  ∂f_t/∂Δu_t = s·(I − Δu_t⊗Δu_t/smooth²),
     so Newton has no way to predict the correction needed to balance the
     friction perturbation.  Even with small μ and tiny load steps the
     residual perturbation kicks Newton out of its basin of attraction
     after iteration 0.

     This file is kept here as the natural integration test for whoever
     adds the analytical friction tangent — it converts straight from
     "diverges" to "few iters per step, quadratic" the moment LHSDriver
     learns about ∂f_t/∂u.

     See README.md in this directory for the follow-up plan and #40 for
     the tracking issue. -->
<tahoe geometry_file="two_cubes.geom"
       output_format="ExodusII"
       title="Implicit sliding cubes with Coulomb friction (#40 — WIP, diverges)">
    <time num_steps="100" output_inc="20" time_step="0.01">
        <schedule_function>
            <piecewise_linear>
                <OrderedPair x="0.0" y="0.0"/>
                <OrderedPair x="1.0" y="1.0"/>
            </piecewise_linear>
        </schedule_function>
    </time>
    <nodes>
        <field field_name="displacement">
            <dof_labels>
                <String value="D_X"/>
                <String value="D_Y"/>
                <String value="D_Z"/>
            </dof_labels>
            <kinematic_BC dof="1" node_ID="1"/>
            <kinematic_BC dof="2" node_ID="1"/>
            <kinematic_BC dof="3" node_ID="1"/>
            <kinematic_BC dof="3" node_ID="2" schedule="1" type="u" value="-0.005"/>
            <kinematic_BC dof="1" node_ID="2" schedule="1" type="u" value="0.01"/>
        </field>
    </nodes>
    <element_list>
        <updated_lagrangian field_name="displacement">
            <hexahedron/>
            <solid_element_nodal_output displacements="1" stress="1"/>
            <large_strain_element_block>
                <block_ID_list>
                    <String value="1"/>
                    <String value="2"/>
                </block_ID_list>
                <large_strain_material_3D>
                    <RG_split_general density="1.0">
                        <rg_eq_potential>
                            <neo-hookean kappa="1000.0" mu="400.0"/>
                        </rg_eq_potential>
                    </RG_split_general>
                </large_strain_material_3D>
            </large_strain_element_block>
        </updated_lagrangian>

        <contact_3D_penalty field_name="displacement"
                            penalty_stiffness="2000.0"
                            friction_coefficient="0.02"
                            friction_epsilon_velocity="1.0e-3">
            <contact_surface>
                <surface_side_set side_set_ID="1"/>
            </contact_surface>
            <contact_surface>
                <surface_side_set side_set_ID="2"/>
            </contact_surface>
            <contact_nodes>
                <node_ID_list>
                    <String value="3"/>
                    <String value="4"/>
                </node_ID_list>
            </contact_nodes>
        </contact_3D_penalty>
    </element_list>
    <nonlinear_solver abs_tolerance="1.0e-8"
                      rel_tolerance="1.0e-6"
                      divergence_tolerance="1.0e+02"
                      max_iterations="30">
        <profile_matrix/>
    </nonlinear_solver>
</tahoe>
