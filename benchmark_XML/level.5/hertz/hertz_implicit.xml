<?xml version="1.0"?>
<!-- Hertz contact benchmark — classic-Tahoe implicit path.
     Same Hertz mesh as the explicit benchmark.  Quasistatic Newton
     iteration with PenaltyContact3DT.  10 monotonic load steps push
     δ = 0..0.05 mm at the sphere top.

     Both blocks share E=200000, ν=0.3 → effective contact modulus
     E* = E/(2(1-ν²)) ≈ 110 GPa, giving a = √(R·δ) ≈ 0.707 mm,
     F_quarter ≈ 1.30 kN, p₀ ≈ 4.94 GPa at the final step. -->
<tahoe geometry_file="geometry/hertz.geom"
       output_format="ExodusII"
       title="hertz_implicit">
    <time num_steps="10" output_inc="1" time_step="0.1">
        <schedule_function>
            <piecewise_linear>
                <OrderedPair x="0.0" y="0.0"/>
                <OrderedPair x="1.0" y="1.0"/>
            </piecewise_linear>
        </schedule_function>
    </time>
    <nodes>
        <field field_name="displacement">
            <dof_labels>
                <String value="D_X"/>
                <String value="D_Y"/>
                <String value="D_Z"/>
            </dof_labels>
            <kinematic_BC dof="3" node_ID="1" schedule="1" type="u" value="-0.05"/>
            <kinematic_BC dof="1" node_ID="2"/>
            <kinematic_BC dof="2" node_ID="3"/>
            <kinematic_BC dof="1" node_ID="4"/>
            <kinematic_BC dof="2" node_ID="4"/>
            <kinematic_BC dof="3" node_ID="4"/>
            <kinematic_BC dof="1" node_ID="5"/>
            <kinematic_BC dof="2" node_ID="6"/>
        </field>
    </nodes>
    <element_list>
        <updated_lagrangian field_name="displacement">
            <hexahedron/>
            <solid_element_nodal_output displacements="1" stress="1"/>
            <!-- block 1: sphere -->
            <large_strain_element_block>
                <block_ID_list><String value="1"/></block_ID_list>
                <large_strain_material_3D>
                    <Simo_isotropic density="7.85">
                        <E_and_nu Poisson_ratio="0.3" Young_modulus="200000.0"/>
                    </Simo_isotropic>
                </large_strain_material_3D>
            </large_strain_element_block>
            <!-- block 2: base (10x stiffer → near-rigid half-space approximation) -->
            <large_strain_element_block>
                <block_ID_list><String value="2"/></block_ID_list>
                <large_strain_material_3D>
                    <Simo_isotropic density="7.85">
                        <E_and_nu Poisson_ratio="0.3" Young_modulus="2000000.0"/>
                    </Simo_isotropic>
                </large_strain_material_3D>
            </large_strain_element_block>
        </updated_lagrangian>

        <contact_3D_penalty field_name="displacement"
                            penalty_stiffness="1.0e6">
            <contact_surface>
                <surface_side_set side_set_ID="1"/>
            </contact_surface>
            <contact_surface>
                <surface_side_set side_set_ID="2"/>
            </contact_surface>
            <contact_nodes>
                <node_ID_list>
                    <String value="7"/>
                </node_ID_list>
            </contact_nodes>
        </contact_3D_penalty>
    </element_list>
    <nonlinear_solver abs_tolerance="1.0e-6"
                      divergence_tolerance="1.0e+04"
                      max_iterations="40"
                      rel_tolerance="1.0e-8">
        <SPOOLES_matrix/>
    </nonlinear_solver>
</tahoe>
