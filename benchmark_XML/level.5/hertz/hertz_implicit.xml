<?xml version="1.0"?>
<!-- Hertz contact benchmark — implicit (classic-Tahoe) path.
     Two elastic bodies in contact: sphere indenter (block 1) on
     elastic base block (block 2).  Both share material:
     E=200000, ν=0.3, ρ=7.85.

     Two-body contact modulus:
       1/E* = (1−ν²)/E_sphere + (1−ν²)/E_base = 2(1−ν²)/E
       E* = E / (2(1−ν²)) ≈ 109 890 MPa

     Hertz at δ_apex = (u_sphere_apex − u_base_apex):
       a   = √(R·δ)
       F   = (4/3) E* √R δ^{3/2}     (full sphere; quarter = F/4)
       p₀  = 3F / (2π a²)
       p_mid (r/a=0.5) = √0.75 · p₀

     δ_apex is the relative apex approach — NOT the prescribed top
     displacement δ_BC = 0.05 mm.  The post-processing script
     computes δ_apex from the simulation and reports Hertz at that. -->
<tahoe geometry_file="geometry/hertz.geom"
       output_format="ExodusII"
       title="hertz_implicit_elastic">
    <time num_steps="10" output_inc="1" time_step="0.1">
        <schedule_function>
            <piecewise_linear>
                <OrderedPair x="0.0" y="0.0"/>
                <OrderedPair x="1.0" y="1.0"/>
            </piecewise_linear>
        </schedule_function>
    </time>
    <nodes>
        <field field_name="displacement">
            <dof_labels>
                <String value="D_X"/>
                <String value="D_Y"/>
                <String value="D_Z"/>
            </dof_labels>
            <!-- sphere top: prescribed downward displacement -->
            <kinematic_BC dof="3" node_ID="1" schedule="1" type="u" value="-0.05"/>
            <!-- sphere x=0, y=0: symmetry -->
            <kinematic_BC dof="1" node_ID="2"/>
            <kinematic_BC dof="2" node_ID="3"/>
            <!-- base bottom: clamped -->
            <kinematic_BC dof="1" node_ID="4"/>
            <kinematic_BC dof="2" node_ID="4"/>
            <kinematic_BC dof="3" node_ID="4"/>
            <!-- base symmetry -->
            <kinematic_BC dof="1" node_ID="5"/>
            <kinematic_BC dof="2" node_ID="6"/>
            <!-- NS8 (base top) is FREE — base deforms elastically under contact load -->
        </field>
    </nodes>
    <element_list>
        <updated_lagrangian field_name="displacement">
            <hexahedron/>
            <solid_element_nodal_output displacements="1" stress="1"/>
            <!-- single material on both blocks -->
            <large_strain_element_block>
                <block_ID_list>
                    <String value="1"/>
                    <String value="2"/>
                </block_ID_list>
                <large_strain_material_3D>
                    <Simo_isotropic density="7.85">
                        <E_and_nu Poisson_ratio="0.3" Young_modulus="200000.0"/>
                    </Simo_isotropic>
                </large_strain_material_3D>
            </large_strain_element_block>
        </updated_lagrangian>

        <contact_3D_penalty field_name="displacement"
                            penalty_stiffness="1.0e7">
            <contact_surface>
                <surface_side_set side_set_ID="1"/>
            </contact_surface>
            <contact_surface>
                <surface_side_set side_set_ID="2"/>
            </contact_surface>
            <contact_nodes>
                <node_ID_list>
                    <String value="7"/>
                </node_ID_list>
            </contact_nodes>
        </contact_3D_penalty>
    </element_list>
    <nonlinear_solver abs_tolerance="1.0e-6"
                      divergence_tolerance="1.0e+04"
                      max_iterations="40"
                      rel_tolerance="1.0e-8">
        <SPOOLES_matrix/>
    </nonlinear_solver>
</tahoe>
