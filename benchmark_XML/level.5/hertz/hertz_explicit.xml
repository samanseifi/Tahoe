<?xml version="1.0"?>
<!-- Hertz contact benchmark — explicit path.
     Quarter-symmetry hemisphere (R=10 mm) on a stiff base, both with
     E=200000, ν=0.3, density=7.85 (consistent units; gives c_p ≈ 159 in
     length/time units).  δ=0.05 mm prescribed at sphere top, ramped
     smoothly over T=1.0 (≈16 wave traversals → quasistatic limit).
     Viscous damping in the contact pair suppresses elastic ringing.

     With identical material on both bodies the effective contact modulus
     is E* = E/(2(1-ν²)) ≈ 110 GPa, giving the analytical predictions:
     a = √(R·δ) ≈ 0.707 mm, F_quarter ≈ 1.30 kN, p₀ ≈ 4.94 GPa.

     Δt = 1e-4 (≈ 0.5× CFL for h_min ≈ 0.12, c_p ≈ 159 in 3D). -->
<tahoe geometry_file="geometry/hertz.geom"
       output_format="ExodusII"
       title="Hertz quarter-sphere on flat base — explicit + viscous damping">
    <time num_steps="10000" output_inc="100" time_step="1.0e-04">
        <!-- Half-cosine smooth ramp y = 0.5(1-cos(πt)) on t∈[0,1] -->
        <schedule_function>
            <piecewise_linear>
                <OrderedPair x="0.0"  y="0.000"/>
                <OrderedPair x="0.1"  y="0.024"/>
                <OrderedPair x="0.2"  y="0.095"/>
                <OrderedPair x="0.3"  y="0.206"/>
                <OrderedPair x="0.4"  y="0.345"/>
                <OrderedPair x="0.5"  y="0.500"/>
                <OrderedPair x="0.6"  y="0.655"/>
                <OrderedPair x="0.7"  y="0.794"/>
                <OrderedPair x="0.8"  y="0.905"/>
                <OrderedPair x="0.9"  y="0.976"/>
                <OrderedPair x="1.0"  y="1.000"/>
            </piecewise_linear>
        </schedule_function>
    </time>
    <nodes>
        <field field_name="displacement" integrator="central_difference">
            <dof_labels>
                <String value="D_X"/>
                <String value="D_Y"/>
                <String value="D_Z"/>
            </dof_labels>
            <kinematic_BC dof="3" node_ID="1" schedule="1" type="u" value="-0.05"/>
            <kinematic_BC dof="1" node_ID="2"/>
            <kinematic_BC dof="2" node_ID="3"/>
            <kinematic_BC dof="1" node_ID="4"/>
            <kinematic_BC dof="2" node_ID="4"/>
            <kinematic_BC dof="3" node_ID="4"/>
            <kinematic_BC dof="1" node_ID="5"/>
            <kinematic_BC dof="2" node_ID="6"/>
        </field>
    </nodes>
    <element_list>
        <explicit_solid field_name="displacement" mass_type="lumped_mass">
            <hexahedron/>
            <solid_element_nodal_output displacements="1" velocities="1" stress="1"/>
            <large_strain_element_block>
                <block_ID_list>
                    <String value="1"/>
                    <String value="2"/>
                </block_ID_list>
                <large_strain_material_3D>
                    <Simo_isotropic density="7.85">
                        <E_and_nu Poisson_ratio="0.3" Young_modulus="200000.0"/>
                    </Simo_isotropic>
                </large_strain_material_3D>
            </large_strain_element_block>
        </explicit_solid>

        <contact_3D_penalty field_name="displacement"
                            penalty_stiffness="1.0e5"
                            viscous_damping="2.0">
            <contact_surface>
                <surface_side_set side_set_ID="1"/>
            </contact_surface>
            <contact_surface>
                <surface_side_set side_set_ID="2"/>
            </contact_surface>
            <contact_nodes>
                <node_ID_list>
                    <String value="7"/>
                </node_ID_list>
            </contact_nodes>
        </contact_3D_penalty>
    </element_list>
    <linear_solver>
        <diagonal_matrix/>
    </linear_solver>
</tahoe>
