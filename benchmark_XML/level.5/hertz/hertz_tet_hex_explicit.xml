<?xml version="1.0"?>
<!-- Hertz contact benchmark — Tet4 indenter on Hex8 base (explicit).
     Same mesh as hertz_tet_hex_implicit.xml.  Uses TWO <explicit_solid>
     element groups so each block can declare its own geometry
     (<tetrahedron/> for block 1, <hexahedron/> for block 2).  Mixed-
     element contact via a single <contact_3D_penalty>: tet triangles
     pair with hex quads (the latter split into 2 triangles internally).

     Δt = 1e-4, T = 1.0 (10 000 steps).  Same ramp as hertz_explicit.xml
     so the late-time state can be compared head-to-head against the
     all-hex run.  Viscous damping suppresses elastic ringing. -->
<tahoe geometry_file="geometry/hertz_tet_hex.geom"
       output_format="ExodusII"
       title="hertz_tet_hex_explicit">
    <time num_steps="10000" output_inc="100" time_step="1.0e-04">
        <schedule_function>
            <piecewise_linear>
                <OrderedPair x="0.0"  y="0.000"/>
                <OrderedPair x="0.1"  y="0.024"/>
                <OrderedPair x="0.2"  y="0.095"/>
                <OrderedPair x="0.3"  y="0.206"/>
                <OrderedPair x="0.4"  y="0.345"/>
                <OrderedPair x="0.5"  y="0.500"/>
                <OrderedPair x="0.6"  y="0.655"/>
                <OrderedPair x="0.7"  y="0.794"/>
                <OrderedPair x="0.8"  y="0.905"/>
                <OrderedPair x="0.9"  y="0.976"/>
                <OrderedPair x="1.0"  y="1.000"/>
            </piecewise_linear>
        </schedule_function>
    </time>
    <nodes>
        <field field_name="displacement" integrator="central_difference">
            <dof_labels>
                <String value="D_X"/>
                <String value="D_Y"/>
                <String value="D_Z"/>
            </dof_labels>
            <kinematic_BC dof="3" node_ID="1" schedule="1" type="u" value="-0.05"/>
            <kinematic_BC dof="1" node_ID="2"/>
            <kinematic_BC dof="2" node_ID="3"/>
            <kinematic_BC dof="1" node_ID="4"/>
            <kinematic_BC dof="2" node_ID="4"/>
            <kinematic_BC dof="3" node_ID="4"/>
            <kinematic_BC dof="1" node_ID="5"/>
            <kinematic_BC dof="2" node_ID="6"/>
            <!-- NS8 (base top) FREE — base deforms elastically -->
        </field>
    </nodes>
    <element_list>
        <!-- block 1 (Tet4 indenter).  Uses ANP F-bar via the explicit
             ANP-Tet4 facility (#28).  The <anp_tet4> tag must come
             AFTER <large_strain_element_block> (XML schema ordering). -->
        <explicit_solid field_name="displacement" mass_type="lumped_mass">
            <tetrahedron/>
            <solid_element_nodal_output displacements="1" velocities="1" stress="1"/>
            <large_strain_element_block>
                <block_ID_list><String value="1"/></block_ID_list>
                <large_strain_material_3D>
                    <Simo_isotropic density="7.85">
                        <E_and_nu Poisson_ratio="0.3" Young_modulus="200000.0"/>
                    </Simo_isotropic>
                </large_strain_material_3D>
            </large_strain_element_block>
            <anp_tet4 enabled="true"/>
        </explicit_solid>

        <!-- block 2 (Hex8 base) -->
        <explicit_solid field_name="displacement" mass_type="lumped_mass">
            <hexahedron/>
            <solid_element_nodal_output displacements="1" velocities="1" stress="1"/>
            <large_strain_element_block>
                <block_ID_list><String value="2"/></block_ID_list>
                <large_strain_material_3D>
                    <Simo_isotropic density="7.85">
                        <E_and_nu Poisson_ratio="0.3" Young_modulus="200000.0"/>
                    </Simo_isotropic>
                </large_strain_material_3D>
            </large_strain_element_block>
        </explicit_solid>

        <contact_3D_penalty field_name="displacement"
                            penalty_stiffness="1.0e7"
                            viscous_damping="2.0">
            <contact_surface>
                <surface_side_set side_set_ID="1"/>
            </contact_surface>
            <contact_surface>
                <surface_side_set side_set_ID="2"/>
            </contact_surface>
            <contact_nodes>
                <node_ID_list>
                    <String value="7"/>
                </node_ID_list>
            </contact_nodes>
        </contact_3D_penalty>
    </element_list>
    <linear_solver>
        <diagonal_matrix/>
    </linear_solver>
</tahoe>
