# ---------------------------------------------------------------------------
# CMake build artifacts
# ---------------------------------------------------------------------------
build/
build-*/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
install_manifest.txt
compile_commands.json
CTestTestfile.cmake
_deps/

# ---------------------------------------------------------------------------
# Compiled object / library / binary files
# ---------------------------------------------------------------------------
*.o
*.lo
*.d
*.a
*.so
*.so.*
*.dylib
*.bak

# ---------------------------------------------------------------------------
# Tahoe simulation output files
# ---------------------------------------------------------------------------
# HDF5 / XDMF output
*.h5
*.xdmf

# Benchmark / run output (generated during test runs)
compare.summary
*.echo.xml
*.io*.geo
*.io*.run
*.io*.run.ps*
*.io*.dat
*.stat
*.out
*.exo
err.txt

# Matrix solver test output (FullMatrixT.LHS.0, CCSMatrixT.LHS.10, etc.)
*MatrixT.LHS.*

# Restart state files written by meshfree/particle tests (*rs50of100, *rs50of100.elem0, etc.)
*[0-9]of[0-9]*

# ---------------------------------------------------------------------------
# IDE and editor files
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Legacy build system leftovers (should not reappear, but guard anyway)
# ---------------------------------------------------------------------------
*.log
all.depend
object_list
src-mirror/
inc/

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
