# ---------------------------------------------------------------------------
# CMake build artifacts
# ---------------------------------------------------------------------------
build/
build-*/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
install_manifest.txt
compile_commands.json
CTestTestfile.cmake
_deps/

# ---------------------------------------------------------------------------
# Compiled object / library / binary files
# ---------------------------------------------------------------------------
*.o
*.lo
*.d
*.a
*.so
*.so.*
*.dylib
*.bak

# ---------------------------------------------------------------------------
# Tahoe simulation output files
# ---------------------------------------------------------------------------
# HDF5 / XDMF output
*.h5
*.xdmf

# Benchmark / run output (generated during test runs)
compare.summary
*.echo.xml
*.io*.geo
*.io*.run
*.io*.run.ps*
*.io*.dat
*.io.ID
*.stat
*.out
*.exo
*.stdout
err.txt
*.tracking
*.rs.tracking

# Bridging element history files (*.rcv, *.hatQ, *.hatU)
*.rcv
*.hatQ
*.hatU

# MPI rank console logs (consoleN, console_3D_static)
console[0-9]*
console_3D_static

# Domain-decomposition output written by `tahoe -decomp_method ... -join_io`:
# per-rank partition files (*.partN) and per-partition geometry trees
# (*.nN.pK.geom, plus the *.es*/.nd/.ns*/.ss* sibling files written next to
# each partitioned .geom).  Regenerated on every parallel run.
*.part[0-9]*
*.n[0-9]*.p[0-9]*.geom
*.n[0-9]*.p[0-9]*.geom.es*
*.n[0-9]*.p[0-9]*.geom.nd
*.n[0-9]*.p[0-9]*.geom.ns*
*.n[0-9]*.p[0-9]*.geom.ss*

# Liquid-inclusion benchmark scratch
benchmark_XML/level.4/liquid_inclusion/J.txt

# Matrix solver test output (FullMatrixT.LHS.0, CCSMatrixT.LHS.10, etc.)
*MatrixT.LHS.*

# Restart state files written by meshfree/particle tests (*rs50of100, *rs50of100.elem0, etc.)
*[0-9]of[0-9]*

# ---------------------------------------------------------------------------
# IDE and editor files
# ---------------------------------------------------------------------------
.vscode/
.idea/
.claude/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Legacy build system leftovers (should not reappear, but guard anyway)
# ---------------------------------------------------------------------------
*.log
all.depend
object_list
src-mirror/
inc/

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo

# ---------------------------------------------------------------------------
# LaTeX build artifacts (doc/src/) — keep .tex sources and the final
# doc/user_guide.pdf only.
# ---------------------------------------------------------------------------
doc/src/*.aux
doc/src/*.bbl
doc/src/*.blg
doc/src/*.lof
doc/src/*.lot
doc/src/*.toc
doc/src/*.out
doc/src/tahoe.user.pdf
